# Required — TiDB connection
TIDB_HOST=your-tidb-host.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_user
TIDB_PASSWORD=your_password
TIDB_DATABASE=celpip
TIDB_SSL_CA=                      # Path to CA cert, e.g. /etc/ssl/certs/ca-certificates.crt

# Required — Clerk authentication
CLERK_JWKS_URL=https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_AUDIENCE=https://your-frontend-domain.com

# App
APP_ENV=development               # development | production
APP_CORS_ORIGINS=http://localhost:3000
